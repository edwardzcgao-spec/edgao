---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const homeEntries = await getCollection(
  'posts',
  ({ data }) => data.publish && data.kind === 'home'
);
const homeEntry = homeEntries[0];
const Content = homeEntry ? (await render(homeEntry)).Content : null;
---

<BaseLayout title="Edward Gao">
  <Hero sentence="Interested in how complicated things actually work — bureaucracies, historical turning points, decisions no single person made." />

  {Content && (
    <article class="prose prose--home">
      <div class="prose__body">
        <Content />
      </div>
    </article>
  )}
</BaseLayout>
