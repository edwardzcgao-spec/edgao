---
// pages/writing.astro — 所有 essay 列表
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleList from '../components/ArticleList.astro';

const essays = await getCollection(
  'posts',
  ({ data }) => data.publish && data.kind === 'essay'
);
const sortedEssays = essays.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Writing — Edward Gao">
  <ArticleList label="essays" posts={sortedEssays} />
</BaseLayout>
