---
// PostLayout.astro
// 单篇文章页:沿用 BaseLayout,加上 prose 容器
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  kind: 'essay' | 'notes';
  description?: string;
}

const { title, date, kind, description } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
});
---

<BaseLayout title={`${title} — Edward Gao`} description={description}>
  <article class="prose">
    <header class="prose__header">
      <p class="prose__kind">{kind}</p>
      <h1 class="prose__title">{title}</h1>
      <p class="prose__date">{formattedDate}</p>
    </header>
    <div class="prose__body">
      <slot />
    </div>
    <a href="/" class="prose__back">← back</a>
  </article>
</BaseLayout>
